# Docker Compose (database)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=aicmpost_db
POSTGRES_PORT=6500

# API server
PORT=8900

# Local DB connection
DATABASE_URL=postgres://postgres:change_me_to_a_strong_password@localhost:6500/aicmpost_db?sslmode=disable

# AI provider (do not commit real values)
# Groq is used for generation, chat, and copilot.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# JWT signing secret
JWT_SECRET=replace_with_a_long_random_secret
